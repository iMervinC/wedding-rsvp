# Resend API Key — get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The couple's email address (receives all RSVPs)
COUPLE_EMAIL=couple@example.com

# The "from" address used in emails sent to guests
# Must be a verified domain in Resend (e.g., noreply@yourdomain.com)
# For testing you can use: onboarding@resend.dev
FROM_EMAIL=noreply@yourdomain.com

# Your site URL (used for OpenGraph / canonical)
NEXT_PUBLIC_SITE_URL=https://yourweddingsite.com

# Google Maps Embed URL (optional)
# Go to Google Maps → Share → Embed a map → copy the src URL
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
